# macOS
.DS_Store
.AppleDouble
.LSOverride

# CircuitPython device output
boot_out.txt

# Credentials — NEVER commit these
settings.toml

# Adafruit bundle archives (large, re-downloadable)
libArchive/

# Top-level experiment ZIP archives
*.zip

# Python cache
__pycache__/
*.pyc
*.pyo

# Empty bundle placeholder
bundles/

# Cursor per-root plan scratch (plans live in the master; sub-root plan dirs are transient).
# Uses **/ to match at any depth so per-experiment .cursor/plans/ folders are also ignored.
**/.cursor/plans/
